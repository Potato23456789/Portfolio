---
import { projects } from '../data/projects.js'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const path = Astro.url.pathname
---
<nav class="sidebar">
  <!-- Section 1: Main nav -->
  <div class="sidebar-section">
    <a href={`${base}/`} class:list={['sidebar-link', { active: path === `${base}/` }]}>
      <span class="sidebar-icon">🏠</span>
      <span data-en="Home" data-vi="Trang chủ">Home</span>
    </a>
    <a href={`${base}/about`} class:list={['sidebar-link', { active: path === `${base}/about` }]}>
      <span class="sidebar-icon">👤</span>
      <span data-en="About" data-vi="Giới thiệu">About</span>
    </a>
  </div>

  <!-- Section 2: Projects (data-driven) -->
  <div class="sidebar-section">
    <div class="sidebar-label" data-en="Projects" data-vi="Dự án">Projects</div>
    {projects.map(p => (
      <a href={`${base}/projects/${p.slug}`}
         class:list={['sidebar-link', { active: path === `${base}/projects/${p.slug}` }]}>
        <span class="sidebar-icon">▶</span>
        <span data-en={p.en.title} data-vi={p.vi.title}>{p.en.title}</span>
      </a>
    ))}
  </div>

  <!-- Section 3: CV -->
  <div class="sidebar-section">
    <div class="sidebar-label" data-en="CV / Resume" data-vi="Hồ sơ">CV / Resume</div>
    <a href={`${base}/cv/en.html`} target="_blank" class="sidebar-link">
      <span class="sidebar-icon">📄</span>
      <span data-en="CV — English" data-vi="CV — Tiếng Anh">CV — English</span>
    </a>
    <a href={`${base}/cv/vi.html`} target="_blank" class="sidebar-link">
      <span class="sidebar-icon">📄</span>
      <span data-en="CV — Vietnamese" data-vi="CV — Tiếng Việt">CV — Vietnamese</span>
    </a>
  </div>

  <!-- Section 4: More -->
  <div class="sidebar-section">
    <a href={`${base}/skills`} class:list={['sidebar-link', { active: path === `${base}/skills` }]}>
      <span class="sidebar-icon">🔧</span>
      <span data-en="Skills" data-vi="Kỹ năng">Skills</span>
    </a>
    <a href={`${base}/contact`} class:list={['sidebar-link', { active: path === `${base}/contact` }]}>
      <span class="sidebar-icon">✉️</span>
      <span data-en="Contact" data-vi="Liên hệ">Contact</span>
    </a>
  </div>
</nav>
